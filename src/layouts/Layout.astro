---
import "../styles/tokens.css";

interface Props {
  title?: string;
}

const { title = "Unruled Play — design, play, games and visual facilitation" } = Astro.props;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href="https://unruledplay.dk" />
    <meta name="description" content="Unruled Play is a design, facilitation, and serious play practice — twenty years of working on hard problems in large enterprises through design, play, games and visual facilitation. Based in Copenhagen." />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://unruledplay.dk" />
    <meta property="og:title" content="Unruled Play — design, play, games and visual facilitation" />
    <meta property="og:description" content="A design, facilitation, and serious play practice — twenty years of working on hard problems in large enterprises through design, play, games and visual facilitation. Based in Copenhagen." />
    <meta property="og:image" content="https://unruledplay.dk/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter / X card (also read by LinkedIn, Slack, Discord, iMessage, WhatsApp) -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Unruled Play — design, play, games and visual facilitation" />
    <meta name="twitter:description" content="A design, facilitation, and serious play practice — twenty years of working on hard problems in large enterprises through design, play, games and visual facilitation. Based in Copenhagen." />
    <meta name="twitter:image" content="https://unruledplay.dk/og-image.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="theme-dark dot-grid">
    <slot />
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html),
  :global(body) {
    margin: 0;
    min-height: 100%;
  }

  :global(body) {
    font-family: var(--font-family-base);
    color: var(--colour-text);
  }
</style>
