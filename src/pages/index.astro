---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Unruled Play">
  <main class="page-shell">
    <nav class="top-nav fade-up" aria-label="Primary navigation">
      <a class="brand" href="/">
        <span class="origami-mark" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="brand-text">
          <span>unruled</span>
          <span class="brand-dot" aria-hidden="true"></span>
          <span>play</span>
        </span>
      </a>

      <div class="nav-actions">
        <ul class="nav-links">
          <li><a href="#">Tools</a></li>
          <li><a href="#">Writing</a></li>
          <li><a href="#">Practice</a></li>
          <li><a href="#">Shop</a></li>
          <li><a href="#">About</a></li>
        </ul>
        <a class="button button-ghost" href="#">Say hello</a>
      </div>
    </nav>

    <section class="hero">
      <h1 class="fade-up">
        In most large enterprises, problem solving and product strategy happens badly, politely, and in slides.
      </h1>
      <p class="subhead fade-up">
        Unruled Play is twenty years of doing the same work in a <em>different</em> room — through design, play, games and visual facilitation.
      </p>

      <div class="cta-row fade-up">
        <a class="button button-primary" href="#">Try the tools &rarr;</a>
        <a class="button button-ghost" href="#">Read the thinking</a>
      </div>

      <dl class="meta-strip fade-up">
        <div>
          <dt>20+</dt>
          <dd>Years in enterprises</dd>
        </div>
        <div>
          <dt>6</dt>
          <dd>Workshop tools, free</dd>
        </div>
        <div>
          <dt>&infin;</dt>
          <dd>Flipcharts, markers, spritzes</dd>
        </div>
      </dl>
    </section>
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1180px, 100%);
    margin: 0 auto;
    padding: 32px 56px;
    display: flex;
    flex-direction: column;
    gap: 3.75rem;
  }

  .top-nav {
    animation-delay: 0s;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: var(--colour-text);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.012em;
  }

  .origami-mark {
    display: inline-grid;
    gap: 0.2rem;
  }

  .origami-mark span {
    width: 1.1rem;
    height: 0.27rem;
    border-radius: var(--radius-pill);
    background: linear-gradient(90deg, var(--colour-accent), var(--colour-primary));
    box-shadow: var(--shadow-soft);
  }

  .origami-mark span:nth-child(2) {
    transform: translateX(0.18rem);
  }

  .origami-mark span:nth-child(3) {
    transform: translateX(0.36rem);
  }

  .brand-text {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .brand-dot {
    width: 0.3rem;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-pill);
    background: var(--colour-blush);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 1.1rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--colour-text);
    opacity: 0.82;
    font-size: 0.94rem;
    transition: opacity var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .nav-links a:hover {
    opacity: 1;
  }

  .hero h1 {
    animation-delay: 0.1s;
    margin: 0;
    max-width: 15ch;
    font-size: var(--font-size-h1);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
  }

  .subhead {
    animation-delay: 0.22s;
    margin: 1.5rem 0 0;
    max-width: 62ch;
    font-size: 1.21rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--colour-text) 90%, white);
  }

  .subhead em {
    color: var(--colour-accent);
    font-style: italic;
  }

  .cta-row {
    animation-delay: 0.34s;
    margin-top: 2.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: var(--radius-pill);
    padding: 0.72rem 1.18rem;
    font-weight: var(--font-weight-semibold);
    font-size: 0.96rem;
    border: 1px solid transparent;
    transition:
      transform var(--motion-duration-fast) var(--motion-ease-standard),
      background-color var(--motion-duration-base) var(--motion-ease-standard),
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      color var(--motion-duration-base) var(--motion-ease-standard);
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--colour-blush);
    color: var(--colour-primary-dark);
    border-color: color-mix(in srgb, var(--colour-blush) 75%, black);
    box-shadow: var(--shadow-soft);
  }

  .button-ghost {
    color: var(--colour-text);
    border-color: var(--colour-border);
    background: color-mix(in srgb, var(--colour-surface-muted) 60%, transparent);
    backdrop-filter: blur(2px);
  }

  .meta-strip {
    animation-delay: 0.6s;
    margin: 2.65rem 0 0;
    padding-top: 1.15rem;
    border-top: 1px solid var(--colour-border);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .meta-strip div {
    display: grid;
    gap: 0.28rem;
  }

  .meta-strip dt {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.1;
    font-weight: var(--font-weight-extrabold);
    color: var(--colour-accent);
  }

  .meta-strip dd {
    margin: 0;
    color: color-mix(in srgb, var(--colour-text) 82%, white);
    font-size: 0.96rem;
  }

  .fade-up {
    opacity: 0;
    transform: translateY(14px);
    animation: fadeUp 550ms var(--motion-ease-standard) forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 820px) {
    .page-shell {
      padding: 24px 22px 32px;
      gap: 2.6rem;
    }

    .nav-links {
      display: none;
    }

    .hero h1 {
      font-size: 40px;
    }

    .subhead {
      font-size: 1.06rem;
      line-height: 1.6;
    }

    .meta-strip {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
  }
</style>
