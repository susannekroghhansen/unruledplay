---
import Layout from "../layouts/Layout.astro";

const substackUrl = "https://bysukro.substack.com/";
const workshopToolsUrl = "https://susannekroghhansen.github.io/workshop-tools/";

const featuredWriting = {
  date: "7 Apr 2026",
  title: "U is for Unfinished",
  excerpt:
    "If I had finished that sketch neatly and confidently, I suspect the conversation would have been shorter, politer, less honest. And maybe it would even have ended with a — oh Susanne you are such a talented artist (which I definitely do not consider myself to be).",
};

const writingPosts = [
  {
    date: "24 Mar 2026",
    title: "D is for Doodles",
    excerpt:
      "Somewhere along the way, doodling got itself a PR problem. A room full of smart adults, suddenly very fascinated by their laptops.",
  },
  {
    date: "14 Mar 2026",
    title: "Sketching abroad",
    excerpt:
      "Turns out that when you let go of perfection, your characters start to talk back. Mine are now sassier than I am. One is demanding a Vespa.",
  },
  {
    date: "12 Feb 2026",
    title: "Stop trying to be Spotify",
    excerpt:
      "We had the ingredients. But not the recipe. And worse — we were trying to follow someone else's cookbook.",
  },
];
---

<Layout title="Unruled Play">
  <main class="page-shell">
    <nav class="top-nav fade-up" aria-label="Primary navigation">
      <a class="brand" href="/">
        <span class="origami-mark" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span class="brand-text">
          <span>unruled</span>
          <span class="brand-dot" aria-hidden="true"></span>
          <span>play</span>
        </span>
      </a>

      <div class="nav-actions">
        <ul class="nav-links">
          <li><a href="#">Tools</a></li>
          <li><a href="#">Writing</a></li>
          <li><a href="#">Practice</a></li>
          <li><a href="#">Shop</a></li>
          <li><a href="#">About</a></li>
        </ul>
        <a class="button button-ghost" href="#">Say hello</a>
      </div>
    </nav>

    <section class="hero">
      <h1 class="fade-up">
        In most large enterprises, problem solving and product strategy happens badly, politely, and in slides.
      </h1>
      <p class="subhead fade-up">
        Unruled Play is twenty years of doing the same work in a <em>different</em> room — through design, play, games and visual facilitation.
      </p>

      <p class="disciplines fade-up">
        Design<span class="sep"></span>Futures scenario building<span class="sep"></span>Visual thinking<span class="sep"></span>Creative confidence<span class="sep"></span>Co-creation<span class="sep"></span>Games<span class="sep"></span>Games-based learning<span class="sep"></span>Organisational change<span class="sep"></span>Digital product development<span class="sep"></span>Facilitation
      </p>

      <div class="cta-row fade-up">
        <a class="button button-primary" href="#">Try the tools &rarr;</a>
        <a class="button button-ghost" href="#">Read the thinking</a>
      </div>

      <dl class="meta-strip fade-up">
        <div>
          <dt>20+</dt>
          <dd>Years in enterprises</dd>
        </div>
        <div>
          <dt>6</dt>
          <dd>Workshop tools, free</dd>
        </div>
        <div>
          <dt>&infin;</dt>
          <dd>Flipcharts, markers, spritzes</dd>
        </div>
      </dl>
    </section>

    <section class="positioning reveal" id="practice">
      <span class="eyebrow">What Unruled Play is</span>
      <p class="lead">Most important decisions in large enterprises get made in rooms that are too small, in formats that are too flat, by people under too much time pressure. The people who know the most are often not in the room at all. And the conversation starts in solution mode — jumping straight to what to build, what to buy, what to launch — before anyone has looked properly at what the problem actually is.</p>
      <p>Unruled Play works on the opposite premise. That the hard problems — strategy, product, change — get better when the room is bigger, the format is visible, and the conversation has real play in it. Twenty years across design, product, and change has taught me one thing without ambiguity. <span class="hard">The room is not a nice-to-have. The room is the work.</span></p>
    </section>

    <section class="expertises reveal" aria-label="Expertises"></section>

    <section class="writing reveal" id="writing">
      <header class="writing-head">
        <p class="eyebrow">Recent writing</p>
        <a class="writing-meta" href={substackUrl} target="_blank" rel="noopener noreferrer">On Substack ↗</a>
      </header>

      <a
        class="post-featured"
        href={substackUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="post-featured-media">
          <svg
            class="post-featured-svg"
            viewBox="0 0 120 120"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M60 14 L106 42 L86 98 L34 98 L14 42 Z"
              fill="currentColor"
              opacity="0.22"
            />
            <path d="M60 14 L60 70 L14 42 Z" fill="currentColor" opacity="0.14" />
            <path d="M60 14 L106 42 L60 70 Z" fill="currentColor" opacity="0.32" />
            <path
              d="M60 70 L86 98 L34 98 Z"
              fill="currentColor"
              opacity="0.2"
            />
          </svg>
        </div>
        <div class="post-featured-body">
          <div class="post-featured-top">
            <span class="post-date">{featuredWriting.date}</span>
            <span class="post-tag">Latest</span>
          </div>
          <h2 class="post-title">{featuredWriting.title}</h2>
          <p class="post-excerpt">{featuredWriting.excerpt}</p>
          <span class="post-cta">Read →</span>
        </div>
      </a>

      <div class="posts-row">
        {
          writingPosts.map((post) => (
            <a
              class="post-card"
              href={substackUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="post-date">{post.date}</span>
              <h3 class="post-title">{post.title}</h3>
              <p class="post-excerpt">{post.excerpt}</p>
              <span class="post-cta">Read →</span>
            </a>
          ))
        }
      </div>

      <footer class="writing-footer">
        <a
          class="button button-ghost writing-subscribe"
          href={substackUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          Subscribe on Substack →
        </a>
      </footer>
    </section>

    <section class="tools reveal" id="tools">
      <header class="tools-head">
        <span class="eyebrow">Workshop tools</span>
      </header>

      <p class="tools-intro">
        The room doesn't need a platform. It needs six small things that work in a browser, read the temperature, hold the parking lot, keep the time. <span class="accent">Workshop Tools is what happens when a facilitator builds the tools she actually wants to use.</span>
      </p>

      <div class="tool-grid">
        <a
          class="tool-card"
          href={workshopToolsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="tool-icon accent-coloured">
            <svg
              class="tool-svg"
              viewBox="0 0 48 48"
              width="48"
              height="48"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                class="outline"
                d="M 26 7 L 13 27 L 22 27 L 19 41 L 35 21 L 25 21 Z"
              />
              <path class="fold" d="M 22 27 L 25 21" />
              <path class="fold" d="M 26 7 L 22 27" />
            </svg>
          </div>
          <span class="tool-name">Energy check-in</span>
          <p class="tool-desc">
            Pulse-check the room before a session. Everyone taps 1–5. The cloud tells you what you're walking into.
          </p>
          <span class="tool-cta">Try it →</span>
        </a>

        <a
          class="tool-card"
          href={workshopToolsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="tool-icon accent-coloured">
            <svg
              class="tool-svg"
              viewBox="0 0 48 48"
              width="48"
              height="48"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                class="outline"
                d="M 22 8 L 22 30 L 17 33 L 17 39 L 24 43 L 31 39 L 31 33 L 26 30 L 26 8 Z"
              />
              <path class="fold" d="M 24 8 L 24 43" />
              <path class="fold" d="M 17 33 L 31 33" />
            </svg>
          </div>
          <span class="tool-name">Temperature check</span>
          <p class="tool-desc">
            Where's the group actually at? One number, one optional word, a shape you can see.
          </p>
          <span class="tool-cta">Try it →</span>
        </a>

        <a
          class="tool-card"
          href={workshopToolsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="tool-icon accent-coloured">
            <svg
              class="tool-svg"
              viewBox="0 0 48 48"
              width="48"
              height="48"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path class="outline" d="M 8 10 L 32 10 L 38 16 L 38 40 L 8 40 Z" />
              <path class="detail" d="M 32 10 L 32 16 L 38 16" />
              <path
                class="outline"
                d="M 16 34 L 16 18 L 26 18 L 26 26 L 16 26 Z"
              />
            </svg>
          </div>
          <span class="tool-name">Parking lot</span>
          <p class="tool-desc">
            Good idea, wrong moment. Park it here and circle back later without breaking the flow.
          </p>
          <span class="tool-cta">Try it →</span>
        </a>

        <a
          class="tool-card"
          href={workshopToolsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="tool-icon accent-coloured">
            <svg
              class="tool-svg"
              viewBox="0 0 48 48"
              width="48"
              height="48"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                class="outline"
                d="M 12 32 L 8 26 L 12 18 L 20 14 L 30 16 L 36 14 L 42 22 L 38 32 L 30 36 L 18 36 Z"
              />
              <path class="fold" d="M 20 14 L 18 36" />
              <path class="fold" d="M 30 16 L 30 36" />
              <path class="fold" d="M 12 18 L 36 14" />
            </svg>
          </div>
          <span class="tool-name">Word cloud</span>
          <p class="tool-desc">
            Ask the room a question. Watch the answers arrive as a shape, not a list.
          </p>
          <span class="tool-cta">Try it →</span>
        </a>

        <a
          class="tool-card"
          href={workshopToolsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="tool-icon accent-coloured">
            <svg
              class="tool-svg"
              viewBox="0 0 48 48"
              width="48"
              height="48"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                class="outline"
                d="M 14 10 L 34 10 L 40 20 L 40 34 L 34 40 L 14 40 L 8 34 L 8 20 Z"
              />
              <path class="fold" d="M 14 10 L 8 20" />
              <path class="fold" d="M 34 10 L 40 20" />
              <path class="detail" d="M 24 18 L 24 26 L 30 30" />
            </svg>
          </div>
          <span class="tool-name">Timer</span>
          <p class="tool-desc">
            Big countdown, full-screen, no fuss. For when an exercise needs a finish line the room can see.
          </p>
          <span class="tool-cta">Try it →</span>
        </a>

        <a
          class="tool-card"
          href={workshopToolsUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="tool-icon accent-coloured">
            <svg
              class="tool-svg"
              viewBox="0 0 48 48"
              width="48"
              height="48"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path class="outline" d="M 10 10 L 28 10 L 34 16 L 34 32 L 10 32 Z" />
              <path class="detail" d="M 28 10 L 28 16 L 34 16" />
              <path class="fold" d="M 10 22 L 34 22" />
              <path
                class="outline"
                d="M 26 32 L 30 38 L 36 40 L 40 36 L 38 30 L 32 28 Z"
              />
              <path class="fold" d="M 32 28 L 36 36" />
            </svg>
          </div>
          <span class="tool-name">Synthesis accelerator</span>
          <p class="tool-desc">
            After the sticky-note storm. Paste the mess, get back a structure you can actually talk to.
          </p>
          <span class="tool-cta">Try it →</span>
        </a>
      </div>

      <p class="tools-footer">
        <strong>All six are free, open to anyone, no account needed.</strong> Built as part of my vibecoding journey — a working proof that the room doesn't need a platform.
      </p>
    </section>
  </main>
</Layout>

<style>
  .page-shell {
    width: min(1180px, 100%);
    margin: 0 auto;
    padding: 32px 56px;
    display: flex;
    flex-direction: column;
    gap: 3.75rem;
  }

  .top-nav {
    animation-delay: 0s;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: var(--colour-text);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.012em;
  }

  .origami-mark {
    display: inline-grid;
    gap: 0.2rem;
  }

  .origami-mark span {
    width: 1.1rem;
    height: 0.27rem;
    border-radius: var(--radius-pill);
    background: linear-gradient(90deg, var(--colour-accent), var(--colour-primary));
    box-shadow: var(--shadow-soft);
  }

  .origami-mark span:nth-child(2) {
    transform: translateX(0.18rem);
  }

  .origami-mark span:nth-child(3) {
    transform: translateX(0.36rem);
  }

  .brand-text {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .brand-dot {
    width: 0.3rem;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-pill);
    background: var(--colour-blush);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 1.1rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--colour-text);
    opacity: 0.82;
    font-size: 0.94rem;
    transition: opacity var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .nav-links a:hover {
    opacity: 1;
  }

  .hero h1 {
    animation-delay: 0.1s;
    margin: 0;
    max-width: 15ch;
    font-size: var(--font-size-h1);
    line-height: var(--line-height-tight);
    letter-spacing: -0.02em;
  }

  .subhead {
    animation-delay: 0.22s;
    margin: 1.5rem 0 0;
    max-width: 62ch;
    font-size: 1.21rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--colour-text) 90%, white);
  }

  .subhead em {
    color: var(--colour-accent);
    font-style: italic;
  }

  .disciplines {
    animation-delay: 0.28s;
    margin: 1.25rem 0 0;
    max-width: 70ch;
    font-size: 0.98rem;
    line-height: 1.65;
    color: color-mix(in srgb, var(--colour-text) 78%, white);
  }

  .disciplines .sep::before {
    content: " · ";
  }

  .cta-row {
    animation-delay: 0.34s;
    margin-top: 2.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border-radius: var(--radius-pill);
    padding: 0.72rem 1.18rem;
    font-weight: var(--font-weight-semibold);
    font-size: 0.96rem;
    border: 1px solid transparent;
    transition:
      transform var(--motion-duration-fast) var(--motion-ease-standard),
      background-color var(--motion-duration-base) var(--motion-ease-standard),
      border-color var(--motion-duration-base) var(--motion-ease-standard),
      color var(--motion-duration-base) var(--motion-ease-standard);
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--colour-blush);
    color: var(--colour-primary-dark);
    border-color: color-mix(in srgb, var(--colour-blush) 75%, black);
    box-shadow: var(--shadow-soft);
  }

  .button-ghost {
    color: var(--colour-text);
    border-color: var(--colour-border);
    background: color-mix(in srgb, var(--colour-surface-muted) 60%, transparent);
    backdrop-filter: blur(2px);
  }

  .meta-strip {
    animation-delay: 0.6s;
    margin: 2.65rem 0 0;
    padding-top: 1.15rem;
    border-top: 1px solid var(--colour-border);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .meta-strip div {
    display: grid;
    gap: 0.28rem;
  }

  .meta-strip dt {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.1;
    font-weight: var(--font-weight-extrabold);
    color: var(--colour-accent);
  }

  .meta-strip dd {
    margin: 0;
    color: color-mix(in srgb, var(--colour-text) 82%, white);
    font-size: 0.96rem;
  }

  .positioning {
    --fg1: var(--colour-text);
    --fg2: color-mix(in srgb, var(--colour-text) 74%, transparent);
    --border: var(--colour-border);
    --muted: color-mix(in srgb, var(--colour-text) 58%, transparent);
    margin-top: 180px;
    max-width: 820px;
  }
  .positioning .eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 36px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
    width: 100%;
  }
  .positioning p {
    margin: 0 0 26px;
    font-size: 22px;
    line-height: 1.55;
    font-weight: 400;
    color: var(--fg2);
    letter-spacing: -0.005em;
    text-wrap: pretty;
  }
  .positioning p.lead {
    color: var(--fg1);
    font-weight: 500;
  }
  .positioning p .hard {
    color: var(--fg1);
    font-weight: 500;
  }

  .writing {
    margin-top: clamp(4rem, 10vw, 10rem);
    width: 100%;
    max-width: 1080px;
    align-self: center;
    --aubergine-600: var(--colour-surface-muted);
    --aubergine-700: color-mix(in srgb, var(--colour-surface) 62%, black);
    --fg1: var(--colour-text);
    --fg2: color-mix(in srgb, var(--colour-text) 74%, transparent);
    --accent: var(--colour-accent);
    --border: var(--colour-border);
    --muted-soft: color-mix(in srgb, var(--colour-text) 58%, transparent);
  }

  .writing-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem 1.5rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--border);
  }

  .writing .eyebrow {
    margin: 0;
    font-size: 0.72rem;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-soft);
  }

  .writing-meta {
    font-size: 0.84rem;
    font-weight: var(--font-weight-medium);
    color: var(--fg2);
    text-decoration: none;
    transition: color var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .writing-meta:hover {
    color: var(--fg1);
  }

  .post-featured {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) 1.2fr;
    border-radius: 14px;
    border: 1px solid var(--border);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: var(--aubergine-600);
  }

  .post-featured-media {
    min-height: 260px;
    background: var(--aubergine-700);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    color: var(--accent);
  }

  .post-featured-svg {
    width: min(200px, 55%);
    height: auto;
  }

  .post-featured-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .post-featured-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }

  .writing .post-date {
    font-size: 11px;
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-soft);
  }

  .post-tag {
    font-size: 10px;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    border-radius: var(--radius-pill);
    padding: 0.2rem 0.55rem;
  }

  .post-featured .post-title {
    margin: 0;
    font-size: clamp(1.35rem, 2.2vw, 1.65rem);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--fg1);
    text-wrap: balance;
  }

  .post-featured .post-excerpt {
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
    color: var(--fg2);
  }

  .writing .post-cta {
    font-size: 13px;
    font-weight: var(--font-weight-semibold);
    color: var(--accent);
  }

  .post-featured .post-cta {
    margin-top: 0.25rem;
  }

  .posts-row {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.35rem;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--aubergine-600);
    text-decoration: none;
    color: inherit;
    transition: transform var(--motion-duration-fast) var(--motion-ease-standard);
  }

  .post-card:hover {
    transform: translateY(-2px);
  }

  .post-card .post-title {
    margin: 0.55rem 0 0;
    font-size: 19px;
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
    color: var(--fg1);
    text-wrap: balance;
  }

  .post-card .post-excerpt {
    margin: 0.45rem 0 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg2);
    flex-grow: 1;
  }

  .post-card .post-cta {
